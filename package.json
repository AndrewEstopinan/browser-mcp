{
  "name": "brightdata-mcp-server",
  "version": "1.0.0",
  "description": "A full-featured Model Context Protocol (MCP) server that lets an AI agent browse and extract data from any public website through Bright Data's Web Access APIs (Unlocker, SERP, Crawl/Web Scraper, and the cloud Browser API with automatic CAPTCHA solving).",
  "type": "module",
  "bin": {
    "brightdata-mcp-server": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "bright-data",
    "brightdata",
    "web-scraping",
    "web-unlocker",
    "serp",
    "browser-api",
    "captcha",
    "ai-agent"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "puppeteer-core": "^23.11.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
