# ---- Required ----
# Your Bright Data API token: https://brightdata.com/cp/setting/users
BRIGHTDATA_API_KEY=your_api_key_here

# ---- Zone names (create under Web Access APIs in the control panel) ----
# Web Unlocker zone (defaults to web_unlocker1 if unset)
BRIGHTDATA_UNLOCKER_ZONE=web_unlocker1
# SERP API zone (defaults to serp_api1 if unset)
BRIGHTDATA_SERP_ZONE=serp_api1

# ---- Browser API (optional; only needed for browser_scrape) ----
# "USER:PASS" from your Browser API zone's Overview tab
BRIGHTDATA_BROWSER_AUTH=brd-customer-XXXX-zone-YYYY:zzzzzzzz
# CDP host (rarely changed)
BRIGHTDATA_BROWSER_HOST=brd.superproxy.io:9222

# ---- Crawl / Web Scraper API (optional) ----
# Default dataset id (gd_...) used when a crawl tool call omits one
BRIGHTDATA_DATASET_ID=

# ---- Advanced ----
# Override the API base URL (rarely needed)
BRIGHTDATA_API_BASE_URL=https://api.brightdata.com
